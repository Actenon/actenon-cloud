# Actenon Cloud — hosted-pilot container settings
# Copy to .env.compose and adjust values for your environment.

# Database
ACTION_CONTROL_PLANE_DATABASE_URL=postgresql+psycopg://actenon:actenon@db:5432/actenon

# Evidence storage (mounted volume)
ACTION_CONTROL_PLANE_EVIDENCE_STORAGE_ROOT=/var/lib/actenon/evidence

# Runtime
ACTION_CONTROL_PLANE_ENVIRONMENT=pilot
ACTION_CONTROL_PLANE_SERVICE_SLUG=action-control-plane
ACTION_CONTROL_PLANE_LOG_FORMAT=console
ACTION_CONTROL_PLANE_API_V1_PREFIX=/api/v1

# Bootstrap admin token (change this in production)
ACTION_CONTROL_PLANE_BOOTSTRAP_ADMIN_TOKEN=change-me-in-production

# Signing (dev — replace with KMS/HSM in production)
ACTION_CONTROL_PLANE_DEV_SIGNING_SECRET=change-me-in-production

# Server
ACTION_CONTROL_PLANE_HOST=0.0.0.0
ACTION_CONTROL_PLANE_PORT=8000

# Evidence durability: filesystem (pilot) — use object storage in production
ACTION_CONTROL_PLANE_EVIDENCE_STORAGE_BACKEND=filesystem
