{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actenon-cloud.local/tests/contract/kernel_pccb.finance.v1alpha1.schema.json",
  "title": "Pinned Kernel-Facing PCCB Contract (Finance v1alpha1)",
  "description": "Local pinned PCCB compatibility contract used by Actenon Cloud contract tests until the upstream Actenon Kernel repo publishes an importable PCCB schema artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_kind",
    "issuer",
    "subject",
    "binding",
    "governance",
    "finance"
  ],
  "properties": {
    "proof_kind": {
      "const": "pccb"
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "uri",
        "trust_tier"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "trust_tier": {
          "type": "string",
          "enum": [
            "development_local",
            "tenant_managed",
            "platform_managed"
          ]
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "action_intent_record_id",
        "external_action_intent_id"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "action_intent_record_id": {
          "type": "string",
          "minLength": 1
        },
        "external_action_intent_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version_ref",
        "action_intent_digest",
        "audience",
        "scope",
        "scope_hash",
        "nonce",
        "issued_at",
        "expires_at"
      ],
      "properties": {
        "contract_version_ref": {
          "const": "open_execution_kernel.action_intent.finance.v1alpha1"
        },
        "action_intent_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scope_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "nonce": {
          "type": "string",
          "minLength": 1
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "policy_version",
        "decision_state",
        "approval_state",
        "evidence_state",
        "matched_rule_id"
      ],
      "properties": {
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "integer",
          "minimum": 1
        },
        "decision_state": {
          "type": "string",
          "enum": [
            "allow",
            "approval_required",
            "needs_evidence"
          ]
        },
        "approval_state": {
          "type": "string",
          "enum": [
            "not_required",
            "satisfied"
          ]
        },
        "evidence_state": {
          "type": "string",
          "enum": [
            "not_required",
            "satisfied"
          ]
        },
        "matched_rule_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "finance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_key",
        "action_type",
        "amount_minor",
        "currency",
        "source_account_ref",
        "destination_account_ref"
      ],
      "properties": {
        "workflow_key": {
          "type": "string",
          "minLength": 1
        },
        "action_type": {
          "type": "string",
          "enum": [
            "payment",
            "transfer",
            "payout",
            "collection",
            "settlement_instruction"
          ]
        },
        "amount_minor": {
          "type": "integer",
          "minimum": 1
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "source_account_ref": {
          "type": "string",
          "minLength": 1
        },
        "destination_account_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
