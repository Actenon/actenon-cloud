# Managed single-tenant hosted pilot environment template.
# Replace placeholder values before use.
#
# Values in the first section are consumed by the application container.
# Values in the second section are operator deployment metadata for the pilot
# environment and are not currently read by the application itself.
#
# This file describes the hosted runtime shape only. The current repo still needs
# an explicit operator bootstrap strategy for fresh hosted environments because the
# built-in bootstrap and dev token issuance flows are local/test-only today.

# Application runtime configuration
ACTION_CONTROL_PLANE_ENVIRONMENT=staging
ACTION_CONTROL_PLANE_HOST=0.0.0.0
ACTION_CONTROL_PLANE_PORT=8000
ACTION_CONTROL_PLANE_LOG_LEVEL=INFO
ACTION_CONTROL_PLANE_LOG_FORMAT=json
ACTION_CONTROL_PLANE_DATABASE_URL=postgresql+psycopg://action_control_plane:replace-with-db-password@managed-postgres.internal:5432/action_control_plane
ACTION_CONTROL_PLANE_EVIDENCE_UPLOAD_BACKEND=filesystem
ACTION_CONTROL_PLANE_EVIDENCE_STORAGE_ROOT=/var/lib/actenon-cloud/evidence
# Future path only. Setting object_store here documents the intended upgrade path but
# does not make live object-store uploads production-ready in this repo build.
# ACTION_CONTROL_PLANE_EVIDENCE_OBJECT_STORE_BUCKET=actenon-cloud-pilot-evidence
ACTION_CONTROL_PLANE_EVIDENCE_OBJECT_STORE_PREFIX=invoice-payment-pilot/evidence
# ACTION_CONTROL_PLANE_EVIDENCE_OBJECT_STORE_ENDPOINT=https://object-storage.example
ACTION_CONTROL_PLANE_PROOF_ISSUER_NAME=Actenon Cloud
ACTION_CONTROL_PLANE_PROOF_ISSUER_URI=https://pilot.actenon-cloud.example/issuer
ACTION_CONTROL_PLANE_PROOF_ISSUER_TRUST_TIER=pilot_managed_environment
ACTION_CONTROL_PLANE_PROOF_DEFAULT_TTL_SECONDS=900
ACTION_CONTROL_PLANE_PROOF_MAX_TTL_SECONDS=86400
ACTION_CONTROL_PLANE_DEV_SIGNING_SECRET=replace-with-long-pilot-signing-secret
ACTION_CONTROL_PLANE_AUTH_MODE=development_signed_bearer
ACTION_CONTROL_PLANE_BOOTSTRAP_ADMIN_TOKEN=replace-with-long-bootstrap-admin-token
ACTION_CONTROL_PLANE_AUTH_OPERATOR_TOKEN_TTL_SECONDS=3600
ACTION_CONTROL_PLANE_AUTH_SERVICE_TOKEN_TTL_SECONDS=3600
ACTION_CONTROL_PLANE_CAPABILITY_RELEASE_MODE=development_simulated
ACTION_CONTROL_PLANE_CAPABILITY_DEFAULT_TTL_SECONDS=600
ACTION_CONTROL_PLANE_CAPABILITY_MAX_TTL_SECONDS=3600
ACTION_CONTROL_PLANE_API_V1_PREFIX=/api/v1
ACTION_CONTROL_PLANE_ENABLE_DOCS=false
ACTION_CONTROL_PLANE_REQUEST_TIMEOUT_SECONDS=30

# Operator deployment metadata, not currently consumed by the application
ACTION_CONTROL_PLANE_PILOT_PUBLIC_HOSTNAME=pilot.actenon-cloud.example
ACTION_CONTROL_PLANE_PILOT_TLS_CERT_PATH=/etc/nginx/tls/actenon-cloud.crt
ACTION_CONTROL_PLANE_PILOT_TLS_KEY_PATH=/etc/nginx/tls/actenon-cloud.key
ACTION_CONTROL_PLANE_PILOT_OBJECT_STORAGE_BUCKET=actenon-cloud-pilot-artifacts
ACTION_CONTROL_PLANE_PILOT_OBJECT_STORAGE_PREFIX=invoice-payment-pilot
ACTION_CONTROL_PLANE_PILOT_OBJECT_STORAGE_ENDPOINT=https://object-storage.example
ACTION_CONTROL_PLANE_PILOT_LOG_COLLECTION_TARGET=central-log-collection
ACTION_CONTROL_PLANE_PILOT_BACKUP_POLICY=db-snapshot-plus-evidence-copy
ACTION_CONTROL_PLANE_PILOT_REVERSE_PROXY_MODE=nginx_tls_termination
