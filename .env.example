# Local defaults only. These values are intentionally development-oriented and
# must not be treated as production trust settings.
ACTION_CONTROL_PLANE_ENVIRONMENT=local
ACTION_CONTROL_PLANE_HOST=127.0.0.1
ACTION_CONTROL_PLANE_PORT=8000
ACTION_CONTROL_PLANE_LOG_LEVEL=INFO
ACTION_CONTROL_PLANE_LOG_FORMAT=json
ACTION_CONTROL_PLANE_DATABASE_URL=sqlite+pysqlite:///./var/action_control_plane.db
ACTION_CONTROL_PLANE_EVIDENCE_UPLOAD_BACKEND=filesystem
ACTION_CONTROL_PLANE_EVIDENCE_STORAGE_ROOT=./var/evidence
# Future path only. Live object-store uploads are not implemented in this repo build yet.
# ACTION_CONTROL_PLANE_EVIDENCE_OBJECT_STORE_BUCKET=
ACTION_CONTROL_PLANE_EVIDENCE_OBJECT_STORE_PREFIX=evidence
# ACTION_CONTROL_PLANE_EVIDENCE_OBJECT_STORE_ENDPOINT=
ACTION_CONTROL_PLANE_PROOF_ISSUER_NAME=Actenon Cloud
ACTION_CONTROL_PLANE_PROOF_ISSUER_URI=https://actenon-cloud.local/issuer
ACTION_CONTROL_PLANE_PROOF_ISSUER_TRUST_TIER=development_local
ACTION_CONTROL_PLANE_PROOF_DEFAULT_TTL_SECONDS=900
ACTION_CONTROL_PLANE_PROOF_MAX_TTL_SECONDS=86400
ACTION_CONTROL_PLANE_DEV_SIGNING_SECRET=action-control-plane-dev-signing-secret
ACTION_CONTROL_PLANE_AUTH_MODE=development_signed_bearer
ACTION_CONTROL_PLANE_BOOTSTRAP_ADMIN_TOKEN=action-control-plane-bootstrap-admin-token
ACTION_CONTROL_PLANE_AUTH_OPERATOR_TOKEN_TTL_SECONDS=3600
ACTION_CONTROL_PLANE_AUTH_SERVICE_TOKEN_TTL_SECONDS=3600
ACTION_CONTROL_PLANE_CAPABILITY_RELEASE_MODE=development_simulated
ACTION_CONTROL_PLANE_CAPABILITY_DEFAULT_TTL_SECONDS=600
ACTION_CONTROL_PLANE_CAPABILITY_MAX_TTL_SECONDS=3600
ACTION_CONTROL_PLANE_API_V1_PREFIX=/api/v1
ACTION_CONTROL_PLANE_ENABLE_DOCS=true
ACTION_CONTROL_PLANE_REQUEST_TIMEOUT_SECONDS=30
ACTION_CONTROL_PLANE_ISSUER_STATUS_AUTHORITY_TYPE=service
ACTION_CONTROL_PLANE_ISSUER_STATUS_AUTHORITY_ID=actenon-issuer-registry
ACTION_CONTROL_PLANE_ISSUER_STATUS_AUTHORITY_DISPLAY_NAME=Actenon Issuer Registry
ACTION_CONTROL_PLANE_ISSUER_STATUS_TTL_SECONDS=300
ACTION_CONTROL_PLANE_ISSUER_STATUS_MAX_STALENESS_SECONDS=300
